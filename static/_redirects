# Redirect from .pages.dev to custom domain
https://jakes-tech-insights.pages.dev/* https://jakeinsight.com/:splat 301!

# Japanese language routes (removed)
/ja/categories/* / 301
/ja/tags/* / 301
/ja/ / 301
/ja/* / 301

# /en/ prefix → actual paths (EN content has no /en/ prefix in Hugo output)
/en/ / 301
/en/all-posts/ /all-posts/ 301
/en/all-posts/* /all-posts/:splat 301
/en/tags/* /tags/:splat 301
/en/categories/* /categories/ 301

# /en/tech/<slug>/ → /tech/<slug>/ (currently-valid date-prefixed URLs)
# Older slug-only /en/tech/<slug>/ URLs will redirect to /tech/<slug>/ which 404s;
# those are unmappable without a Worker. The /en/* prefix removal is still useful
# for the vast majority of inbound links that have correct date-prefixed slugs.
/en/tech/* /tech/:splat 301

# /en/side-income/* — same pattern; date-prefixed slugs map cleanly, undated slugs
# from before the convention will land at /side-income/<old-slug>/ which 404s
/en/side-income/* /side-income/:splat 301

# Legacy section landings (no slug) for completeness
/en/tech/ /tech/ 301
/en/side-income/ /side-income/ 301

# Live category pages — explicit 200 (no redirect)
# These MUST be listed before any /categories/* catch-all
/categories/ /categories/ 200
/categories/tech/ /categories/tech/ 200
/categories/side-income/ /categories/side-income/ 200
/ko/categories/ /ko/categories/ 200
/ko/categories/tech/ /ko/categories/tech/ 200
/ko/categories/side-income/ /ko/categories/side-income/ 200

# Trailing-slash normalization
/categories/tech /categories/tech/ 301

# Legacy URLs are intentionally NOT listed — they fall through to Cloudflare's
# default 404, which is sufficient to remove them from Google's index.
# (Cloudflare Pages _redirects does not support status 410, only 200/301/302/303/307/308.)
#
# Removed legacy patterns (now 404):
#   /technologies/*, /tags/mini/
#   /sports/*, /business/*, /entertainment/*, /society/*, /finance/*
#   /ko/sports/*, /ko/business/*, /ko/entertainment/*, /ko/society/*, /ko/finance/*
#   /categories/business/, /categories/entertainment/, /categories/sports/, etc.
#   Old undated tech posts
